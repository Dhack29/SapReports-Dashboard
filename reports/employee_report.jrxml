<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" 
              name="dynamic_report" 
              pageWidth="595" pageHeight="842" columnWidth="555" 
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" 
              uuid="e7e59600-9856-42d4-a169-7ee47530d1c8">
	
    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="PostgresAdapter"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	
    <!-- Styles for alternating rows -->
    <style name="Zebra" mode="Opaque" backcolor="#FFFFFF">
		<conditionalStyle>
			<conditionExpression><![CDATA[$V{REPORT_COUNT}%2 == 1]]></conditionExpression>
			<style mode="Opaque" backcolor="#F4F6F6"/>
		</conditionalStyle>
	</style>

	<queryString>
		<![CDATA[SELECT distinct mapped_rs_code, count(*) as count FROM warranty_dipek group by mapped_rs_code]]>
	</queryString>
	
    <field name="mapped_rs_code" class="java.lang.String"/>
	<field name="count" class="java.lang.Long"/>
	
    <!-- Variables for statistics -->
    <variable name="TotalRecords" class="java.lang.Long" calculation="Sum">
        <variableExpression><![CDATA[$F{count}]]></variableExpression>
    </variable>

	<background>
		<band splitType="Stretch"/>
	</background>
	
